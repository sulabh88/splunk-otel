d. Take a Snapshot Using etcdctl
bash
Copy
Edit
export ETCDCTL_API=3
export NODE_NAME=$(hostname)
sudo -E etcdctl \
  --cacert=/etc/kubernetes/static-pod-resources/etcd-certs/etcd-ca.crt \
  --cert=/etc/kubernetes/static-pod-resources/etcd-certs/etcd-client.crt \
  --key=/etc/kubernetes/static-pod-resources/etcd-certs/etcd-client.key \
  snapshot save /home/core/etcd-backup/snapshot.db
